{
  "name": "keystore-maker",
  "version": "0.0.1",
  "description": "Cross-platform Android keystore generator and signature fingerprint viewer.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test tests/*.test.js",
    "pack": "electron-builder --dir",
    "dist:mac": "electron-builder --mac dmg zip",
    "dist:win": "electron-builder --win nsis portable --x64",
    "dist": "electron-builder --mac dmg zip --win nsis portable --x64"
  },
  "build": {
    "appId": "com.local.keystoremaker",
    "productName": "Keystore Maker",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    }
  },
  "dependencies": {
    "node-forge": "^1.3.1"
  },
  "devDependencies": {
    "electron": "^39.0.0",
    "electron-builder": "^26.0.0"
  }
}
